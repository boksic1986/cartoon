# Providers default to mock for the first milestone.
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
TTS_PROVIDER=mock

# Local paths
OUTPUT_DIR=./outputs
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_DIR=./workflows/comfyui

# API keys, never commit real values.
OPENAI_API_KEY=
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=
TTS_API_KEY=

# Defaults
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_WIDTH=1080
DEFAULT_HEIGHT=1920
DEFAULT_IMAGE_WIDTH=768
DEFAULT_IMAGE_HEIGHT=1344
DEFAULT_DURATION_SECONDS=45
MAX_SCENES=10
MAX_VIDEO_SECONDS=60

