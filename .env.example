# 第一阶段 provider 默认使用 mock。
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
TTS_PROVIDER=mock

# 本地路径
OUTPUT_DIR=./outputs
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_DIR=./workflows/comfyui

# API key 示例必须留空，不要写入真实值。
# BytePlus ModelArk 官方示例常用 ARK_API_KEY；本项目也兼容 SEEDANCE_API_KEY。
ARK_API_KEY=
OPENAI_API_KEY=
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL_NAME=seedance-1-0-pro-250528
TTS_API_KEY=

# 默认参数
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_WIDTH=1080
DEFAULT_HEIGHT=1920
DEFAULT_IMAGE_WIDTH=768
DEFAULT_IMAGE_HEIGHT=1344
DEFAULT_DURATION_SECONDS=45
MAX_SCENES=10
MAX_VIDEO_SECONDS=60
